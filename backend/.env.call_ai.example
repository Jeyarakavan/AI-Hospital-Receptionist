# Call AI agent <-> backend auth
CALL_AI_SHARED_TOKEN=replace_with_long_random_token

# Call AI runtime config
CALL_AI_BACKEND_BASE_URL=http://127.0.0.1:8000
CALL_AI_STT_CONFIDENCE_THRESHOLD=0.55
CALL_AI_INTENT_CONFIDENCE_THRESHOLD=0.70
CALL_AI_MAX_RETRIES=2
CALL_AI_MAX_TURNS=20
CALL_AI_HOSPITAL_NAME=Jaffna Hospital
CALL_AI_EMERGENCY_PROMPT=Please contact emergency services or our emergency unit immediately.

# STT (faster-whisper)
CALL_AI_WHISPER_MODEL=small.en
CALL_AI_WHISPER_COMPUTE_TYPE=int8

# TTS (piper)
CALL_AI_PIPER_BIN=/usr/local/bin/piper
CALL_AI_PIPER_MODEL=/opt/piper/en_US-lessac-medium.onnx
CALL_AI_PIPER_SPEAKER=0
CALL_AI_TTS_OUTPUT_DIR=/tmp/call_ai_tts
CALL_AI_ASTERISK_SOUNDS_DIR=/var/lib/asterisk/sounds
CALL_AI_RECORDING_DIR=/tmp/call_ai_recordings
